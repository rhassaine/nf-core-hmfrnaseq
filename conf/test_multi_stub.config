/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Nextflow config file for running multi-sample stub tests
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Stub test with 3 samples to validate multi-sample channel routing.
    Uses unique nf-core/rnaseq test FASTQs to ensure each STAR task has
    a unique hash. Catches queue/value channel bugs that single-sample
    tests miss.

    Use as follows:
        nextflow run . -profile test_multi_stub,docker --outdir <OUTDIR> -stub

----------------------------------------------------------------------------------------
*/

process {

    resourceLimits = [
        cpus: 4,
        memory: '15.GB',
        time: '1.h'
    ]

}

params {
    config_profile_name        = 'Multi-sample stub test profile'
    config_profile_description = 'Stub test with 3 samples to validate multi-sample channel routing'

    // Input data — 3 samples with unique FASTQs
    input = "${projectDir}/tests/samplesheet_multi_sample_stub.csv"

    // Reference data (local stubs, no downloads)
    genomes {

        'GRCh38_hmf' {
            fasta         = "temp/GRCh38.fasta"
            fai           = "temp/GRCh38.fai"
            dict          = "temp/GRCh38.dict"
            star_index    = "temp/GRCh38_star_index/"
        }

    }

    ref_data_hmf_data_path = "temp/hmf_bundle_38/"

    // Analysis config
    mode                     = 'rna_redux_workflow'
    genome                   = 'GRCh38_hmf'
    max_fastq_records        = 0
    skip_sortmerna           = true
    ref_data_genome_gtf      = "temp/gencode.v38.annotation.gtf"
    create_stub_placeholders = true
}
