/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Nextflow config file for running full pipeline stub tests
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Stub test for full RNA pipeline (STAR + REDUX + AMBER + RSeQC + Isofox)
    with local placeholder references. No remote data staging required.

    Use as follows:
        nextflow run . -profile test_full_stub,docker --outdir <OUTDIR> -stub

----------------------------------------------------------------------------------------
*/

process {

    resourceLimits = [
        cpus: 4,
        memory: '15.GB',
        time: '1.h'
    ]

}

params {
    config_profile_name        = 'Full stub test profile'
    config_profile_description = 'Stub test for full RNA pipeline with placeholder references'

    // Input data
    input = params.pipelines_testdata_base_path + '/samplesheet/fastq_eval.subject_a.wgts.trna.minimal.csv'

    // Reference data (local stubs, no downloads)
    genomes {

        'GRCh38_hmf' {
            fasta         = "temp/GRCh38.fasta"
            fai           = "temp/GRCh38.fai"
            dict          = "temp/GRCh38.dict"
            star_index    = "temp/GRCh38_star_index/"
        }

    }

    ref_data_hmf_data_path = "temp/hmf_bundle_38/"

    // Analysis config
    mode                     = 'rna_redux_workflow'
    genome                   = 'GRCh38_hmf'
    max_fastq_records        = 0
    skip_sortmerna           = true
    rseqc_bed_file           = "temp/rseqc.bed"
    create_stub_placeholders = true
}
